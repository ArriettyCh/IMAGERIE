# Database configuration
DATABASE_URL="mysql://root:password@localhost:3306/image_manager?schema=public"

# JWT authentication
JWT_SECRET="your-secret-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server configuration
PORT=3001
NODE_ENV=development

# File upload configuration
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Optional AI and geocoding providers
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="gpt-4o-mini"
AMAP_API_KEY=""